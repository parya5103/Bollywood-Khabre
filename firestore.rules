rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Bootstrapped admin logic
      return isSignedIn() && (
        request.auth.token.email == 'aaryapratik@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidNewsArticle(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'slug', 'publishedAt']) && 
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.category in ['Bollywood', 'Hollywood', 'Trending', 'Reviews'] &&
             data.slug is string && data.slug.size() <= 256 &&
             data.publishedAt is string; // Simplified for string date
    }

    function isValidStats(data) {
      return data.keys().hasAll(['totalArticles', 'seoHealth', 'monthlyEst']) &&
             data.totalArticles is number &&
             data.seoHealth is number &&
             data.monthlyEst is number;
    }

    // --- Collection Rules ---

    match /articles/{articleId} {
      allow read: if true; // Publicly readable
      
      allow create: if isAdmin() && 
                      isValidId(articleId) && 
                      isValidNewsArticle(incoming());
      
      allow update: if isAdmin() && 
                      isValidNewsArticle(incoming()) && (
                        // Standard update: allow modifying everything except immutable fields if needed
                        incoming().slug == existing().slug &&
                        incoming().publishedAt == existing().publishedAt
                      );

      allow delete: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidStats(incoming());
    }

    match /admins/{adminId} {
      allow read, write: if false; // Only manageable via Cloud Console or privileged backend
    }
  }
}
